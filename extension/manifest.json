{
  "manifest_version": 3,
  "name": "EduAdapt",
  "version": "1.0",
  "description": "Reshapes any webpage for students with Dyslexia or ADHD using Gemini AI.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],

  "host_permissions": [
    "https://eduadapt-api.vercel.app/*"
  ]
}